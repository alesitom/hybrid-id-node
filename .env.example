# HybridId configuration — read by HybridIdGenerator.fromEnv().
# Copy to `.env` and load it before constructing the generator:
#   - recommended:  import 'dotenv/config'             (npm i dotenv)
#   - zero-dep:     node --env-file=.env your-app.js   (Node >= 20.6, nothing to install)
#
# This library reads process.env directly and bundles no .env loader, so
# hybrid-id itself stays dependency-free either way.

# Profile: compact | standard | extended (or a registered custom profile).
HYBRID_ID_PROFILE=standard

# Two base62 characters (0-9 A-Z a-z) identifying this node/process.
# Required for standard/extended unless HYBRID_ID_REQUIRE_NODE=0.
# Sensitive-ish: keep consistent per node to avoid cross-node collisions.
HYBRID_ID_NODE=A1

# Set to 0 to disable the explicit-node guard (local dev only).
# HYBRID_ID_REQUIRE_NODE=1

# Blind mode — HMAC-hash the timestamp+node so creation time is unextractable.
# HYBRID_ID_BLIND=1

# Base64-encoded 32+ byte HMAC secret for reproducible blind IDs.
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
#
# SECRET — treat like a signing key. Keep it server-side ONLY.
# NEVER expose it through a client-bundled env (e.g. a VITE_-prefixed var):
# those are shipped to the browser.
# HYBRID_ID_BLIND_SECRET=

# Optional hard cap on full ID length (including prefix).
# HYBRID_ID_MAX_LENGTH=
